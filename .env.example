# ─── Bitacora App Dashboard — Environment Variables ───────────────
# Copy this file to .env and fill in the values.

# ─── Server (required in production) ─────────────────────────────

# Session secret — used to sign session cookies (min 32 random bytes recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_ME

# Encryption key — must be exactly 64 hex characters (32 bytes) for AES-256-GCM
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_ME

# YouTrack instance URL (no trailing slash)
YOUTRACK_URL=https://bitacora.youtrack.cloud

# YouTrack permanent token — used by the server for agent ingest sync.
# Create one in YouTrack: Profile → Account Security → Tokens.
# This is NOT a per-user token; it's a service-level credential.
YOUTRACK_TOKEN=

# Server port (default: 8080)
PORT=8080

# Ingest token — agents use this to push markdown plans via /api/ingest/*
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INGEST_TOKEN=

# ─── Claude Code Agent Telemetry ─────────────────────────────────
# Enables OpenTelemetry tracking for agent sessions (token usage, cost, tool calls)
CLAUDE_CODE_ENABLE_TELEMETRY=1

# Exporter: "console" for local debugging, "otlp" for production backend
OTEL_METRICS_EXPORTER=console
OTEL_LOGS_EXPORTER=console

# For OTLP backend (uncomment when collector is running on VPS):
# OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Resource attributes — tags every metric with repo + team context
OTEL_RESOURCE_ATTRIBUTES=repo=bitacora-app-dashboard,team=primo-engineering

# ─── Registration ─────────────────────────────────────────────────
# Required for all registrations after the first admin account exists.
# Leave blank to disable self-registration entirely after setup.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REGISTRATION_TOKEN=
